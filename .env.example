# -----------------------------------------------------------------------------
# CMS (/admin) environment — copy this file to `.env.local` and fill in values.
# Phase 6 of the portfolio build. See portfolio_build_plan.md for the full flow.
# -----------------------------------------------------------------------------

# --- GitHub repo coordinates (where CMS saves commit) ------------------------
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_REPO_BRANCH=main

# --- GitHub OAuth App --------------------------------------------------------
# Create at https://github.com/settings/developers → New OAuth App.
# Authorization callback URL: http://localhost:3000/api/auth/callback (dev)
#                             https://<your-domain>/api/auth/callback (prod)
# Scope requested: `public_repo` — if you flip the repo to private, swap to
# `repo` in app/api/auth/github/route.ts and re-authorize.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Single-user allow-list --------------------------------------------------
# GitHub login (username) — the callback refuses any other account. Case-
# insensitive match (we `.toLowerCase()` both sides before comparing).
ADMIN_GITHUB_LOGIN=

# --- JWE session cookie secret -----------------------------------------------
# Generate once with: `openssl rand -base64 32`. Must be ≥32 chars.
# Rotating this invalidates every live session cookie.
SESSION_COOKIE_SECRET=

# --- Base URL for OAuth callback ---------------------------------------------
# http://localhost:3000 in dev, https://<your-domain> in prod.
ADMIN_BASE_URL=http://localhost:3000

# --- Dev-only escape hatch (optional) ----------------------------------------
# If set AND NODE_ENV !== "production", server actions fall back to this PAT
# when no OAuth session cookie is present. Useful for headless / scripted
# edits in local dev. Generate at https://github.com/settings/tokens?type=beta
# with `contents=write` scoped to the target repo only. Do NOT set in prod.
GITHUB_TEST_TOKEN=

# -----------------------------------------------------------------------------
# CMS (/admin) environment — copy this file to `.env.local` and fill in values.
# Phase 6 of the portfolio build. See portfolio_build_plan.md for the full flow.
# -----------------------------------------------------------------------------

# --- GitHub repo coordinates (where CMS saves commit) ------------------------
# Step 4 uses a throwaway branch (`cms-test`) so the save pipeline can be
# verified without touching production. Step 5 flips this to `main`.
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_REPO_BRANCH=cms-test

# --- Step 4 test token (replaced by OAuth in Step 6) -------------------------
# A personal access token with `public_repo` scope. Generate at
# https://github.com/settings/tokens?type=beta — fine-grained, scoped to just
# this repo with contents=write. Delete this env var once Step 6 ships.
GITHUB_TEST_TOKEN=

# --- GitHub OAuth App (filled in Step 6) -------------------------------------
# Create at https://github.com/settings/developers → New OAuth App.
# Authorization callback URL: http://localhost:3000/api/auth/callback (dev)
#                             https://siladityaa.com/api/auth/callback (prod)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Single-user allow-list (Step 6) -----------------------------------------
# GitHub login (username) — must exactly match the account that signs in.
ADMIN_GITHUB_LOGIN=

# --- JWE session cookie secret (Step 6) --------------------------------------
# Generate once: `openssl rand -base64 32`
SESSION_COOKIE_SECRET=

# --- Base URL for OAuth callback (Step 6) ------------------------------------
# http://localhost:3000 in dev, https://siladityaa.com in prod.
ADMIN_BASE_URL=http://localhost:3000
